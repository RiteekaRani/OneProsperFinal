        "hero": {
          "type": "HeroTwoColumn",
          "lhs": {
            "h1": "Read and Rise: Girls Educating Girls",
            "subhead": "A 10-week English Learning Buddy program connecting high school girls in the U.S./Canada with girls in India for weekly conversation and reading practice.",
            "bridgeLine": "Read and Rise is a sister organization to OneProsper International.",
            "primaryCTA": { "label": "Join Read and Rise", "action": "openJoinFlow" },
            "secondaryCTA": { "label": "Donate", "action": "goToDonate" }
          },
          "rhs": {
            "media": { "kind": "imageOrVideo", "assetId": "hero_media_placeholder" }
          }
        },
        "segments": {
          "Students": {
            "sections": [
              {
                "id": "3.1",
                "type": "Cards3WithImages",
                "title": "Why this matters",
                "intro": "Many students learn English in school — but confidence grows through regular conversation.",
                "cards": [
                  {
                    "imageAssetId": "students_challenge_1",
                    "headline": "Conversation practice is limited",
                    "body": "Students often don’t get enough speaking time to build comfort and fluency."
                  },
                  {
                    "imageAssetId": "students_challenge_2",
                    "headline": "Confidence affects opportunity",
                    "body": "Speaking confidently can unlock participation, leadership, and future pathways."
                  },
                  {
                    "imageAssetId": "students_challenge_3",
                    "headline": "Mentorship is powerful",
                    "body": "A consistent peer relationship helps students stay motivated and supported."
                  }
                ]
              },
              {
                "id": "3.2",
                "type": "Cards3WithImages",
                "title": "The Read and Rise Buddy Program",
                "intro": "Simple structure. Real impact. One weekly commitment.",
                "cards": [
                  {
                    "imageAssetId": "students_solution_1",
                    "headline": "Get paired with a learner",
                    "body": "You’ll be matched with a learner in India for a 10-week program."
                  },
                  {
                    "imageAssetId": "students_solution_2",
                    "headline": "Meet weekly for 30 minutes",
                    "body": "Use Zoom/Meet to practice conversational English and read together."
                  },
                  {
                    "imageAssetId": "students_solution_3",
                    "headline": "Follow a clear lesson plan",
                    "body": "We provide weekly materials so you always know what to do."
                  }
                ]
              },
              {
                "id": "3.3",
                "type": "Stats3Boxes",
                "title": "Proven impact",
                "stats": [
                  { "value": "5,000+", "label": "Learners enrolled since 2020" },
                  { "value": "7,500+", "label": "Volunteer hours delivered" },
                  { "value": "98.6%", "label": "Would recommend to a friend" }
