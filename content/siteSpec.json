      "routes": [
        { "path": "/", "title": "Home" },
        { "path": "/about", "title": "About Us" },
        { "path": "/donate", "title": "Donate" },
        { "path": "/signup", "title": "Sign Up" },
        { "path": "/privacy-policy", "title": "Privacy Policy" },
        { "path": "/terms-of-service", "title": "Terms of Service" }
      ]
    },
