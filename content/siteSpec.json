        "type": "StickyNav",
        "sticky": true,
        "items": [
          { "label": "OneProsper", "href": "/", "kind": "logo" },
          { "label": "About Us", "href": "/about", "kind": "link" },
          { "label": "Donate", "href": "/donate", "kind": "ctaSecondary" },
          { "label": "Sign Up", "href": "/signup", "kind": "ctaPrimary" }
        ]
      },
      "donateCTA": {
        "label": "Donate",
        "href": "/donate",
        "placements": ["nav", "hero", "donateSection", "footer"]
      },
