      "relationshipNote": "Read and Rise is a sister organization to OneProsper International.",
      "primaryGoals": [
        "Fundraising and donation collection (Donately)",
        "Buddy signups (USA/Canada high school girls)",
        "School-admin signups (USA/Canada high school administrators)"
      ]
    },
